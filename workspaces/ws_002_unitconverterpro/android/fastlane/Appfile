# Fastlane Appfile — Unit Converter Pro (Android / Google Play)
# json_key_file points to the Play service account JSON (gitignored).
# Override with PLAY_JSON_KEY_FILE env var for CI.

package_name("com.appfactory.unitconverterpro")
json_key_file(ENV["PLAY_JSON_KEY_FILE"] || File.expand_path("../../../../../config/play_service_account.json", __FILE__))
