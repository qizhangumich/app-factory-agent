<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        Base theme. The app UI is fully Jetpack Compose Material 3 and is
        always dark (per spec). This theme only needs to host the splash /
        window background before Compose takes over.
    -->
    <style name="Theme.QRBarcodeScanner" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/black</item>
        <item name="android:statusBarColor">@color/black</item>
        <item name="android:navigationBarColor">@color/black</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

</resources>
