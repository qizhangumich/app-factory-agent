<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Base application theme. The actual Compose UI colors come from
        PomodoroTheme; this Android theme only styles the splash window and
        system bars before Compose takes over.
    -->
    <style name="Theme.PomodoroFocus" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:navigationBarColor">@color/background_dark</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
