<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ backup / device-transfer rules. -->
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="pomodoro.db" />
        <include domain="file" path="datastore/" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="pomodoro.db" />
        <include domain="file" path="datastore/" />
    </device-transfer>
</data-extraction-rules>
