# Fastlane credentials for Android account android_001 (Mirror Utilities)
# [HUMAN GATE] Copy this file to android_001.env and fill in real values. Never commit the .env file.

# Google Play service account JSON key — create in Google Cloud Console,
# grant it access in Play Console > Users and permissions.
export PLAY_JSON_KEY_ANDROID_001="config/fastlane_env/play-android-001.json"

# Upload keystore for signing the release AAB.
export ANDROID_KEYSTORE_PATH_001="config/fastlane_env/android-001-upload.keystore"
export ANDROID_KEYSTORE_PASSWORD_001="set-a-strong-password"
export ANDROID_KEY_ALIAS_001="upload"
export ANDROID_KEY_PASSWORD_001="set-a-strong-password"
