# Fastlane credentials for iOS account ios_001 (Utilities + Productivity)
# [HUMAN GATE] Copy this file to ios_001.env and fill in real values. Never commit the .env file.

# Apple ID email for this developer account
export APPLE_ID_IOS_001="dev-ios-001@example.com"

# App Store Connect Team ID (found in App Store Connect > Membership)
export TEAM_ID_IOS_001="XXXXXXXXXX"

# Developer Portal Team ID (usually same as TEAM_ID)
export ITC_TEAM_ID_IOS_001="XXXXXXXXX"

# App Store Connect API key (avoids 2FA on CI) — generate at
# https://appstoreconnect.apple.com/access/api
export ASC_KEY_ID_IOS_001="XXXXXXXXXX"
export ASC_ISSUER_ID_IOS_001="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
export ASC_KEY_PATH_IOS_001="config/fastlane_env/AuthKey_XXXXXXXXXX.p8"

# fastlane match — private git repo holding signing certs, and its passphrase
export MATCH_GIT_URL="git@github.com:youraccount/app-factory-certs.git"
export MATCH_PASSWORD="set-a-strong-passphrase"
