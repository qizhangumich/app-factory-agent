# App Factory v2 — fastlane match configuration (code signing).
# match stores signing certificates + provisioning profiles in a private git
# repo so every account and CI machine signs consistently.
#
# The git URL and passphrase come from the per-account .env file
# (MATCH_GIT_URL, MATCH_PASSWORD) loaded before fastlane runs.

git_url(ENV["MATCH_GIT_URL"])
storage_mode("git")

type("appstore")          # default; "development" also synced when needed

# app_identifier and username are supplied per app by the deploy script /
# per-app Appfile, so they are intentionally not hard-coded here.
#
# Don't pin readonly here. The Fastfile's match() call passes
# readonly: false so the first run for each new bundle id can create
# the per-app provisioning profile in the encrypted repo. The
# Matchfile used to hardcode readonly(true), which silently overrode
# the Fastfile and broke first-time setup for new apps.
