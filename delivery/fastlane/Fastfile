require "tmpdir"
require "json"

default_platform(:ios)

platform :ios do
  desc "Build, sign, and upload an iOS app to App Store Connect"
  lane :deploy do |options|
    app_dir   = options[:app_dir]                      # path to workspace/ios
    scheme    = options[:scheme]
    bundle_id = options[:bundle_id]

    # CI bootstrap: create a temporary, unlocked keychain so codesign
    # can access the imported certificate without showing a GUI
    # password prompt. Without this, the macOS runner hangs at the
    # "Signing X.app" step forever (until the 45-min workflow timeout).
    # No-op when running locally on a developer Mac.
    setup_ci if ENV["CI"] == "true"

    # App Store Connect API key auth — CI-friendly, no 2FA.
    # We DELIBERATELY do not call fastlane's `app_store_connect_api_key`
    # action: in fastlane 2.236+ it pollutes lane_context with a key that
    # gym then auto-injects as `api_key:` — a parameter gym doesn't accept,
    # which crashes the build before xcodebuild runs. Each downstream
    # action takes the key via api_key_path (path to JSON) or env vars.
    have_api_key = ENV["ASC_KEY_ID"] && ENV["ASC_ISSUER_ID"] && ENV["ASC_KEY_PATH"]

    # Build the JSON form that fastlane's cert / sigh / deliver actions
    # expect for api_key_path. (Their api_key_path wants a JSON, not the
    # raw .p8.) Written once, reused by every downstream action.
    asc_json = nil
    if have_api_key
      asc_json = File.join(Dir.tmpdir, "asc_api_key.json")
      File.write(asc_json, JSON.dump({
        key_id:    ENV["ASC_KEY_ID"],
        issuer_id: ENV["ASC_ISSUER_ID"],
        key:       File.read(ENV["ASC_KEY_PATH"]),
        duration:  1200,
        in_house:  false,
      }))
    end

    # Match: stores the Apple Distribution certificate and provisioning
    # profile in a private git repo (qizhangumich/app-factory-certs),
    # encrypted with MATCH_PASSWORD. Every CI run downloads + decrypts
    # the same cert.p12 instead of creating a new one — which is what
    # blew us past Apple's 2-cert limit when we were using cert+sigh.
    #
    # match reads MATCH_GIT_URL, MATCH_PASSWORD, and
    # MATCH_GIT_BASIC_AUTHORIZATION from env vars automatically.
    # api_key_path makes it use the ASC API key (no 2FA prompts).
    #
    # readonly: false so the FIRST run for each new bundle id can
    # create + push the cert/profile to the encrypted repo. Subsequent
    # runs reuse it. force: false so we never blow away existing certs
    # unless we explicitly opt in.
    match(
      type:            "appstore",
      app_identifier:  bundle_id,
      api_key_path:    asc_json,
      readonly:        false,
      force:           false,
    )

    # Build the signed .ipa. We use Manual signing here (overriding the
    # project's CODE_SIGN_STYLE=Automatic via xcargs) because xcodebuild
    # archive with Automatic + ASC API key keeps trying to provision an
    # "iOS App Development" profile (which needs registered devices on
    # the team). Manual signing with the profile sigh just created
    # bypasses that whole flow.
    profile_name_env = "sigh_#{bundle_id}_appstore_profile-name"
    profile_name     = ENV[profile_name_env] || ""

    xcargs_parts = [
      "-allowProvisioningUpdates",
      "DEVELOPMENT_TEAM=#{ENV['APPLE_TEAM_ID']}",
      "CODE_SIGN_STYLE=Manual",
      'CODE_SIGN_IDENTITY="Apple Distribution"',
    ]
    xcargs_parts << "PROVISIONING_PROFILE_SPECIFIER=\"#{profile_name}\"" unless profile_name.empty?

    gym(
      scheme: scheme,
      project: "#{app_dir}/#{scheme}.xcodeproj",
      output_directory: "#{app_dir}/build",
      output_name: "#{scheme}.ipa",
      clean: true,
      export_method: "app-store",
      export_team_id: ENV["APPLE_TEAM_ID"],
      xcargs: xcargs_parts.join(" "),
    )

    # Upload binary to App Store Connect. submit_for_review stays false:
    # the human gate clicks the final "Submit for Review" button.
    #
    # NOTE: skip_metadata + skip_screenshots for now. Reason: the iOS
    # metadata layout deliver expects is
    #   metadata/<locale>/name.txt, description.txt, …
    #   metadata/<locale>/screenshots/<DeviceClass>/*.png
    # but our workspace currently has an Android-style flat structure.
    # Wiring iOS metadata is a separate step — for now we just push the
    # signed .ipa so App Store Connect has a build to attach to the
    # listing the user already created. Listing text + screenshots are
    # entered via the App Store Connect UI for now (5 apps × 5 min).
    deliver_args = {
      app_identifier:                    bundle_id,
      ipa:                               "#{app_dir}/build/#{scheme}.ipa",
      submit_for_review:                 false,
      automatic_release:                 false,
      force:                             true,
      skip_metadata:                     true,
      skip_screenshots:                  true,
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit:        false,
    }
    deliver_args[:api_key_path] = asc_json if have_api_key
    deliver(deliver_args)
  end

  desc "Generate framed screenshots for an iOS app"
  lane :screenshots do |options|
    app_dir = options[:app_dir]
    snapshot(
      project: "#{app_dir}/#{options[:scheme]}.xcodeproj",
      scheme: "#{options[:scheme]}UITests",
      output_directory: "#{app_dir}/fastlane/metadata/screenshots",
      languages: ["en-US", "ja", "de-DE", "ko", "zh-Hans"],
      devices: [
        "iPhone 15 Pro Max",
        "iPhone 15 Pro",
        "iPad Pro (12.9-inch) (6th generation)"
      ],
      clear_previous_screenshots: true
    )
    frameit(path: "#{app_dir}/fastlane/metadata/screenshots")
  end
end

platform :android do
  desc "Upload a signed AAB to Google Play internal track (human gate promotes to production)"
  # options:
  #   app_dir       – absolute path to workspace/android (e.g. workspaces/ws_001.../android)
  #   bundle_id     – package name (e.g. com.appfactory.tipcalcdeluxe)
  #   json_key      – path to Google Play service account JSON key file
  #   rebuild       – if true, run bundleRelease before uploading (default: false)
  lane :deploy do |options|
    app_dir   = options[:app_dir]
    bundle_id = options[:bundle_id]
    json_key  = options[:json_key] || ENV["PLAY_JSON_KEY_FILE"] || "config/play_service_account.json"
    rebuild   = options.fetch(:rebuild, false)

    if rebuild
      gradle(
        project_dir: app_dir,
        task: "bundle",
        build_type: "Release"
      )
    end

    aab_path = "#{app_dir}/app/build/outputs/bundle/release/app-release.aab"
    UI.user_error!("AAB not found: #{aab_path}") unless File.exist?(aab_path)

    supply(
      package_name:            bundle_id,
      json_key:                json_key,
      aab:                     aab_path,
      track:                   "internal",
      release_status:          "draft",
      metadata_path:           "#{app_dir}/fastlane/metadata/android",
      skip_upload_metadata:    false,
      skip_upload_images:      true,
      skip_upload_screenshots: true,
      version_code_auto_increment: false,
    )
  end
end
